{
  "permissions": {
    "allow": ["Read:*", "Bash:git:*", "Bash:npm:*", "Bash:npx:*", "Bash:node:*", "Bash:pnpm:*"],
    "deny": ["Read:env:*", "Bash:sudo:*", "Bash:rm -rf:*"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-check.sh"
          }
        ]
      }
    ]
  }
}
